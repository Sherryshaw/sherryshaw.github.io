pan class=\"number\">0</span>) &#123;</span><br><span class=\"line\">                    <span class=\"keyword\">if</span>(type==<span class=\"number\">1</span>||specialtype==<span class=\"number\">1</span>) &#123;</span><br><span class=\"line\"></span><br><span class=\"line\">                        <span class=\"keyword\">if</span>(!(i-l&lt;<span class=\"number\">0</span>||i+<span class=\"number\">1</span>+l&gt;=s.length())&amp;&amp;s.charAt(i-l)==s.charAt(i+<span class=\"number\">1</span>+l)) &#123;</span><br><span class=\"line\">                            l++;</span><br><span class=\"line\">                        &#125;<span class=\"keyword\">else</span> <span class=\"keyword\">if</span>(specialtype==<span class=\"number\">1</span>) &#123;</span><br><span class=\"line\">                            tmpl=l;</span><br><span class=\"line\">                            l=<span class=\"number\">0</span>;</span><br><span class=\"line\">                            type=<span class=\"number\">2</span>;</span><br><span class=\"line\">                            specialtype=<span class=\"number\">2</span>;</span><br><span class=\"line\">                        &#125;<span class=\"keyword\">else</span> &#123;</span><br><span class=\"line\">                            <span class=\"keyword\">break</span>;</span><br><span class=\"line\">                        &#125;</span><br><span class=\"line\">                    &#125;</span><br><span class=\"line\">                    <span class=\"keyword\">else</span> <span class=\"keyword\">if</span>(type==<span class=\"number\">2</span>||specialtype==<span class=\"number\">2</span>) &#123;</span><br><span class=\"line\">                        <span class=\"keyword\">if</span>(!(i-l&lt;<span class=\"number\">0</span>||i+l&gt;=s.length())&amp;&amp;s.charAt(i-l)==s.charAt(i+l)) &#123;</span><br><span class=\"line\"></span><br><span class=\"line\">                            l++;</span><br><span class=\"line\">                        &#125;<span class=\"keyword\">else</span> <span class=\"keyword\">if</span>(specialtype==<span class=\"number\">2</span>) &#123;</span><br><span class=\"line\">                            <span class=\"keyword\">if</span>((<span class=\"number\">2</span>*(tmpl))&gt;(<span class=\"number\">2</span>*l-<span class=\"number\">1</span>)) &#123;</span><br><span class=\"line\">                                l=tmpl;</span><br><span class=\"line\">                                type=<span class=\"number\">1</span>;</span><br><span class=\"line\">                                <span class=\"keyword\">break</span>;</span><br><span class=\"line\">                            &#125;<span class=\"keyword\">else</span> &#123;</span><br><span class=\"line\">                                type=<span class=\"number\">2</span>;</span><br><span class=\"line\">                                <span class=\"keyword\">break</span>;</span><br><span class=\"line\">                            &#125;</span><br><span class=\"line\">                        &#125;<span class=\"keyword\">else</span>&#123;</span><br><span class=\"line\">                            <span class=\"keyword\">break</span>;</span><br><span class=\"line\">                        &#125;</span><br><span class=\"line\">                    &#125;</span><br><span class=\"line\">                &#125;</span><br><span class=\"line\">                <span class=\"keyword\">switch</span>(type) &#123;</span><br><span class=\"line\">                <span class=\"keyword\">case</span> <span class=\"number\">1</span>:&#123;</span><br><span class=\"line\">                    <span class=\"keyword\">if</span>(max&lt;=(<span class=\"number\">2</span>*(l))) &#123;</span><br><span class=\"line\">                        max=(<span class=\"number\">2</span>*(l));</span><br><span class=\"line\">                        begin=i-l+<span class=\"number\">1</span>;</span><br><span class=\"line\">                    &#125;</span><br><span class=\"line\">                &#125;<span class=\"keyword\">break</span>;</span><br><span class=\"line\">                <span class=\"keyword\">case</span> <span class=\"number\">2</span>:&#123;</span><br><span class=\"line\">                    <span class=\"keyword\">if</span>(max&lt;=(<span class=\"number\">2</span>*l-<span class=\"number\">1</span>)) &#123;</span><br><span class=\"line\">                        max=(<span class=\"number\">2</span>*l-<span class=\"number\">1</span>);</span><br><span class=\"line\">                        begin=i-l+<span class=\"number\">1</span>;</span><br><span class=\"line\">                    &#125;</span><br><span class=\"line\">                &#125;<span class=\"keyword\">break</span>;</span><br><span class=\"line\">                &#125;</span><br><span class=\"line\"></span><br><span class=\"line\"></span><br><span class=\"line\">            &#125;</span><br><span class=\"line\">            <span class=\"keyword\">return</span> s.substring(begin, begin+max);</span><br><span class=\"line\">        &#125;</span><br><span class=\"line\">    &#125;</span><br></pre></td></tr></table></figure>\n<h2 id=\"结果\"><a href=\"#结果\" class=\"headerlink\" title=\"结果\"></a>结果</h2><p><img src=\"https://ae01.alicdn.com/kf/Hdea44eb8ff0849d8980078cde52098acJ.png\" alt=\"Markdown\"></p>\n<h2 id=\"总结\"><a href=\"#总结\" class=\"headerlink\" title=\"总结\"></a>总结</h2><p>在该题中，我的代码应该有一定的冗余，原因是之前错认为求得是最长回文字符串的长度，改完之后又忽略了“ccc”这样的单字母的回文字符串，所以该代码是在之前错误代码的基础上修改的。<br>我的思路是，先对字符串s进行一次遍历，在这次遍历中，这一位便是回文字符串的中间位，这时会分为3种情况</p>\n<ol>\n<li><strong>该位与下一位相等</strong>：此时该位与下一位共同成为回文字符串的中心，即类似“abba”这样的字符串，这时进行以这两位为中心，向两端扩散的遍历，直到两端不等为止</li>\n<li><strong>该位的上一位与下一位相等</strong>：此时该位成为回文字符串的中心，即类似“aba”这样的字符串，这时进行以这两位为中心，向两端扩散的遍历，直到两端不等为止</li>\n<li><strong>该位与该位的上一位和下一位均相等</strong>：此时不能确定谁为回文字符串的中心，即类似“aaa”这样的字符串，这时因为我们向周围同时扩散，在这之前我们不能确定回文字符串的长度，如果为“aaaa”那就是第一种情况，而如果为“aaaaa”那就是第二种情况了，所以我将他定义为特殊类型，遇到这种情况时，先按类型1遍历得到长度，再按类型2遍历得到长度，两者之间取最大值便是该回文字符串了。</li>\n</ol>\n<p>情况3是我刚接触这个题时完全没有想到的，但是这种情况只要仔细想一下还是能想的通。下面是我在LeetCode中的提交结果<br><img src=\"https://ae01.alicdn.com/kf/Hf0d73bcdd1b84413bc7c71c479516342b.png\" alt=\"Markdown\"><br><a href=\"https://leetcode-cn.com/problems/longest-palindromic-substring/submissions/\">点击去往LeetCode开始答题</a></p>","categories":[{"name":"开发","path":"api/categories/开发.json"}],"tags":[{"name":"JAVA","path":"api/tags/JAVA.json"},{"name":"算法","path":"api/tags/算法.json"}]}