ass=\"string\">&#x27;(&#x27;</span>)==-<span class=\"number\">1</span>) &#123;</span><br><span class=\"line\">                <span class=\"keyword\">return</span> result;</span><br><span class=\"line\">            &#125;</span><br><span class=\"line\">            <span class=\"keyword\">for</span>(<span class=\"keyword\">int</span> i=<span class=\"number\">0</span>;i&lt;s.length();i++) &#123;</span><br><span class=\"line\">                <span class=\"keyword\">boolean</span> flag=<span class=\"keyword\">true</span>;</span><br><span class=\"line\">                <span class=\"keyword\">int</span> j=<span class=\"number\">0</span>;</span><br><span class=\"line\">                <span class=\"keyword\">int</span> tmp=<span class=\"number\">0</span>;</span><br><span class=\"line\">                <span class=\"keyword\">int</span> level=<span class=\"number\">0</span>;</span><br><span class=\"line\">                List list=<span class=\"keyword\">new</span> ArrayList();</span><br><span class=\"line\">                <span class=\"keyword\">while</span>(flag&amp;&amp;i+j&lt;s.length()) &#123;</span><br><span class=\"line\">                    <span class=\"keyword\">char</span> c=s.charAt(i+j);</span><br><span class=\"line\">                    <span class=\"keyword\">switch</span>(c) &#123;</span><br><span class=\"line\">                    <span class=\"keyword\">case</span> <span class=\"string\">&#x27;(&#x27;</span>:&#123;</span><br><span class=\"line\">                        list.add(c);</span><br><span class=\"line\">                        &#125;;<span class=\"keyword\">break</span>;</span><br><span class=\"line\">                    <span class=\"keyword\">case</span> <span class=\"string\">&#x27;)&#x27;</span>:&#123;</span><br><span class=\"line\">                        <span class=\"keyword\">if</span>(list.size()&gt;<span class=\"number\">0</span>) &#123;</span><br><span class=\"line\">                            list.remove(list.size()-<span class=\"number\">1</span>);</span><br><span class=\"line\">                        &#125;<span class=\"keyword\">else</span> &#123;</span><br><span class=\"line\">                            flag=<span class=\"keyword\">false</span>;</span><br><span class=\"line\">                        &#125;</span><br><span class=\"line\">                    &#125;;<span class=\"keyword\">break</span>;</span><br><span class=\"line\">                    &#125;</span><br><span class=\"line\"></span><br><span class=\"line\">                    <span class=\"keyword\">if</span>(flag) &#123;</span><br><span class=\"line\">                        j++;</span><br><span class=\"line\">                        tmp++;</span><br><span class=\"line\">                    &#125;</span><br><span class=\"line\">                    <span class=\"keyword\">if</span>(list.size()==<span class=\"number\">0</span>) &#123;</span><br><span class=\"line\">                        level+=tmp;</span><br><span class=\"line\">                        tmp=<span class=\"number\">0</span>;</span><br><span class=\"line\">                    &#125;</span><br><span class=\"line\">                &#125;</span><br><span class=\"line\">                <span class=\"keyword\">if</span>(level&gt;result) &#123;</span><br><span class=\"line\">                    result=level;</span><br><span class=\"line\">                &#125;</span><br><span class=\"line\">            &#125;</span><br><span class=\"line\">            <span class=\"keyword\">return</span> result;</span><br><span class=\"line\">        &#125;</span><br><span class=\"line\">&#125;</span><br></pre></td></tr></table></figure>\n<h3 id=\"运行结果\"><a href=\"#运行结果\" class=\"headerlink\" title=\"运行结果\"></a>运行结果</h3><p><img src=\"https://ae01.alicdn.com/kf/Hb58e660b79d54b0995a2315affecf4b8e.png\"></p>\n<h2 id=\"总结\"><a href=\"#总结\" class=\"headerlink\" title=\"总结\"></a>总结</h2><p>这道题是昨天做的，有一些事，所以没来得及写博客，我的思路主要就是遍历s，从每个字符串开始，括号匹配的方法和之前<a href=\"https://www.thzone.cn/20190920/201